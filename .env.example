# DeepSeek API Key（可选 — 用户可在网页侧边栏输入自己的Key）
# 如果部署到公网，建议留空让用户自带Key；如果本地只用，可填写自己的Key
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 邮件配置（可选 — 排版完成后自动发送邮件给用户）
# QQ邮箱: 设置 → 账户 → POP3/SMTP服务 → 开启 → 生成授权码
EMAIL_HOST=smtp.163.com
EMAIL_PORT=465
EMAIL_USER=your_email@163.com
EMAIL_PASS=your_smtp_password_or_auth_code
